# Copy this file to .env and replace placeholders with your own values.
# Never commit .env. It is ignored by git.

# ---------------------------------------------------------------------------
# Required for live AWS ingestion, training, prediction, and deploy
# ---------------------------------------------------------------------------
AWS_REGION=eu-west-3
AWS_PROFILE=dpl
S3_BUCKET_RAW=
ATHENA_DATABASE=dpl_pilot
ATHENA_OUTPUT_LOCATION=

# AISStream is the only required third-party secret for the current live pilot.
# Keep the real value in .env, GitHub Actions secrets, or AWS Secrets Manager.
AISSTREAM_API_KEY=

# ---------------------------------------------------------------------------
# Optional SAM deployment parameters
# ---------------------------------------------------------------------------
ALERT_EMAIL=
AIS_DURATION_SECONDS=300
PUBLIC_DASHBOARD_BUCKET_NAME=
PUBLIC_DASHBOARD_OBJECT_KEY=demo-data.js
PUBLIC_DASHBOARD_DISTRIBUTION_ID=
PREDICTIONS_OBJECT_KEY=predictions.json

# ---------------------------------------------------------------------------
# Optional dashboard live-data source
# Local dashboard dev works without this because it uses public/demo-data.js.
# For Vercel, set this in the Vercel project environment instead.
# ---------------------------------------------------------------------------
VITE_DATA_URL=

# ---------------------------------------------------------------------------
# Optional local/legacy Postgres loader configuration
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dpl_dev
POSTGRES_USER=dpl
POSTGRES_PASSWORD=replace-with-local-password

# ---------------------------------------------------------------------------
# Optional future/extended data sources
# ---------------------------------------------------------------------------
FRED_API_KEY=
NOAA_API_TOKEN=
CMEMS_USERNAME=
CMEMS_PASSWORD=
MAERSK_API_KEY=
CMACGM_API_KEY=
