# Copy this file to .env and fill in real values
# DO NOT commit .env (it is in .gitignore)

# AISStream.io — https://aisstream.io
AISSTREAM_API_KEY=your_aisstream_key_here

# FRED — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# NOAA — https://www.ncdc.noaa.gov/cdo-web/token
NOAA_API_TOKEN=your_noaa_token_here

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-placeholder
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-placeholder

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=placeholder

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=placeholder

# Local Postgres (dev)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dpl_dev
POSTGRES_USER=dpl
POSTGRES_PASSWORD=change_me_locally

# AWS (real credentials live in ~/.aws/credentials via aws configure)
AWS_REGION=eu-west-3
AWS_PROFILE=dpl
S3_BUCKET_RAW=data-party-logistics-raw
POSTGRES_HOST=your-rds-endpoint.eu-west-3.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DB=dpl_dev
POSTGRES_USER=dpl
POSTGRES_PASSWORD=changeme
